# Linguist: config/data/i18n dosyaları hariç, gerçek React kodu (JS/JSX) görünür kalır
finance-frontend/public/**        linguist-detectable=false
finance-frontend/src/i18n/**      linguist-detectable=false
finance-frontend/*.json           linguist-detectable=false
finance-frontend/*.js             linguist-detectable=false
