# ======================================================
# Repo-Wide Ignore — applies to all subdirectories
# ======================================================

# Secrets & local configs (KEEP OUT OF GIT)
**/.env
**/.env.local
**/.env.*.local
**/application-local.yml
**/application-local.yaml
**/application-local.properties

# Keycloak realm export (LDAP bind credentials, default admin password vb. icerir)
finance-realm*.json

# GCP Service Account JSON keys
*.gcp-key.json
gcp-sa-key.json
**/credentials.json

# Open-cluster.ps1 runtime'da uretir (hostname patched)
k8s/network/*.RUNTIME.yaml

# Personal local scripts (not part of project)
make_commits.ps1
run.local.ps1
*.local.ps1

# IDE / editor
.vscode/
.idea/
*.iml
*.iws
*.ipr

# Build artifacts
**/target/
**/build/
**/dist/
**/dist-ssr/
!**/src/main/**/build/
!**/src/test/**/build/

# Node / Vite
**/node_modules/
**/.vite/
**/.cache/
*.tsbuildinfo

# Logs
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Python (if any leftover)
**/__pycache__/
**/*.pyc
**/.venv/
**/venv/

# Maven
.mvn/wrapper/maven-wrapper.jar

# Spring Boot leftover
.springBeans
.sts4-cache
.factorypath
.classpath
.project
.settings/
.apt_generated

# Java
*.class
hs_err_pid*

# Sonar local state (her koşumda yenilenir, repoya gitmez)
**/.scannerwork/

# Spring Initializr leftover — Maven projesi açılır açılmaz oluşur, referans dokümanı, ihtiyaç yok
HELP.md

# HTTP test client dosyaları (IntelliJ .http vb.) — local credential içerebilir
*.http

# Geliştirme aşamasında üretilen faz/iç dokümanlar (FAZA-1, CLEANUP-REPORT, ROADMAP vb.)
**/FAZA-*.md
**/CLEANUP-REPORT.md
**/REFACTORING-ROADMAP.md

# Maven Central metadata indirildiğinde takılan rastgele kalıntılar
metadata.xml
maven-metadata.xml

# Keycloak generated themes (optional — uncomment if you don't want them tracked)
# **/keycloak-themes/
