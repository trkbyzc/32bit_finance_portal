{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["finance-portal", "observability", "logs"],
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "refresh": "10s",
  "title": "Finance Portal — Loglar & Trace Korelasyonu",
  "uid": "finance-portal-logs",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Toplam Log",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "*", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ] }
      ],
      "options": { "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "text" } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "INFO",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "level:INFO", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ] }
      ],
      "options": { "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "WARN",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "level:WARN", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ] }
      ],
      "options": { "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "ERROR",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "level:ERROR", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ] }
      ],
      "options": { "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log Hacmi — seviyeye göre (API Trafiği)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "*", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "level.keyword", "settings": { "size": "6", "order": "desc", "orderBy": "_count", "min_doc_count": "0" } },
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0", "trimEdges": "0" } }
          ] }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" }, "lineWidth": 1 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] },
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      }
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Seviyeye Göre Dağılım",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "*", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [ { "id": "2", "type": "terms", "field": "level.keyword", "settings": { "size": "10", "order": "desc", "orderBy": "_count" } } ] }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }, "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "En Çok Log Üreten Servisler",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "*", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "count", "settings": {} } ],
          "bucketAggs": [ { "id": "2", "type": "terms", "field": "logger_name.keyword", "settings": { "size": "8", "order": "desc", "orderBy": "_count" } } ] }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "showUnfilled": true },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "continuous-GrYlRd" } } }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Canlı Sistem Akışı — trace_id / span_id (traceId'ye tıkla → Tempo)",
      "gridPos": { "h": 13, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        { "refId": "A", "queryType": "lucene", "query": "*", "timeField": "@timestamp",
          "metrics": [ { "id": "1", "type": "raw_data", "settings": { "size": "200" } } ], "bucketAggs": [] }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "^(@timestamp|level|logger_name|mdc\\.traceId|mdc\\.spanId|message)$" } } },
        { "id": "organize", "options": {
            "indexByName": { "@timestamp": 0, "level": 1, "mdc.traceId": 2, "mdc.spanId": 3, "logger_name": 4, "message": 5 },
            "renameByName": { "@timestamp": "Zaman", "level": "Seviye", "mdc.traceId": "traceId", "mdc.spanId": "spanId", "logger_name": "Servis", "message": "Mesaj" }
        } }
      ],
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true, "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceId" },
            "properties": [
              { "id": "custom.width", "value": 270 },
              { "id": "links", "value": [
                {
                  "title": "Trace'i Tempo'da aç",
                  "url": "",
                  "internal": {
                    "datasourceUid": "tempo",
                    "datasourceName": "Tempo",
                    "query": { "query": "${__value.raw}", "queryType": "traceql" }
                  }
                }
              ] }
            ]
          },
          { "matcher": { "id": "byName", "options": "spanId" }, "properties": [ { "id": "custom.width", "value": 160 } ] },
          { "matcher": { "id": "byName", "options": "Zaman" }, "properties": [ { "id": "custom.width", "value": 200 } ] },
          { "matcher": { "id": "byName", "options": "Seviye" }, "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "ERROR": { "color": "red", "index": 0 }, "WARN": { "color": "yellow", "index": 1 }, "INFO": { "color": "green", "index": 2 } } }
              ] },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
          ] }
        ]
      }
    }
  ]
}
