# =====================================================================
# 🔒 .env DOSYASI TEMPLATE'İ
# =====================================================================
# Bu dosyayı kopyala → `.env` olarak yeniden adlandır → kendi key'lerini gir.
# `.env` gitignore'da; gerçek key'ler GitHub'a gitmez.
#
# docker-compose.yml'in app-backend servisi bu env'leri okur ve container'a
# enjekte eder. Boş bırakırsan ilgili özellik warning atar (kritik servisler
# etkilenmez): EVDS = TCMB ekonomik veri sync'i, FRED = ABD eko verisi,
# FMP/Finnhub = ABD hisse senedi fundamentals, LLM = chatbot, Mail = alarm bildirimi.

# --- 3rd party API anahtarları ---
EVDS_API_KEY=
FRED_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=

# --- LLM (chatbot için) ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Mail (fiyat alarmı bildirimleri için Gmail SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_ENABLED=false
APP_MAIL_FROM=noreply@finansportal.local
APP_MAIL_FROM_NAME=FinansPortal
