<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <!-- charset="UTF-8" şart: Windows default cp1254/cp857 Türkçe karakteri mojibake ediyor ("EMTİA" → "EMT─░A") -->
            <PatternLayout charset="UTF-8" pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p [%t] [TraceId: %X{traceId:-}] [SpanId: %X{spanId:-}] %c{1}:%L - %m%n" />
        </Console>

        <Kafka name="Kafka" topic="finance-app-logs" syncSend="false">
            <JsonTemplateLayout eventTemplateUri="classpath:LogstashJsonEventLayoutV1.json"/>
            <Property name="bootstrap.servers">localhost:9092</Property>
        </Kafka>
    </Appenders>

    <Loggers>
        <!-- Kafka'nın kendi hatalarını Kafka'ya göndermesini engelle, sadece konsola yaz -->
        <Logger name="org.apache.kafka" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console" />
            <AppenderRef ref="Kafka" />
        </Root>
    </Loggers>
</Configuration>