<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <!-- charset="UTF-8" şart: Windows default cp1254/cp857 Türkçe karakteri mojibake ediyor ("EMTİA" → "EMT─░A") -->
            <!-- trace_id / span_id: OTel Java Agent (-javaagent) ThreadContext'e bu anahtarlarla yazar.
                 (Eski micrometer-tracing 'traceId'/'spanId' kullanıyordu; agent'a geçişte snake_case oldu.) -->
            <PatternLayout charset="UTF-8" pattern="%d{yyyy-MM-dd HH:mm:ss} %-5p [%t] [TraceId: %X{trace_id:-}] [SpanId: %X{span_id:-}] %c{1}:%L - %m%n" />
        </Console>

        <!-- Kafka -> Logstash -> OpenSearch (finance-logs-*). Özel şablon trace_id'yi
             mdc.traceId'ye eşler; mevcut OpenSearch dashboard'ları değişmeden çalışır. -->
        <Kafka name="Kafka" topic="finance-app-logs" syncSend="false">
            <JsonTemplateLayout eventTemplateUri="classpath:finance-event-template.json"/>
            <!-- KAFKA_LOG_BOOTSTRAP_SERVERS env varsa kullan, yoksa localhost (lokal dev). -->
            <Property name="bootstrap.servers">${env:KAFKA_LOG_BOOTSTRAP_SERVERS:-localhost:9092}</Property>
        </Kafka>
    </Appenders>

    <Loggers>
        <!-- Kafka'nın kendi hatalarını Kafka'ya göndermesini engelle, sadece konsola yaz -->
        <Logger name="org.apache.kafka" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console" />
            <AppenderRef ref="Kafka" />
        </Root>
    </Loggers>
</Configuration>